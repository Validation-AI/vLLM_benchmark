 #!/bin/bash
 set -e
 
+# Parse TP configuration (e.g., 1P2D)
+parse_tp_config() {
+    local config=$1
+    # Extract P and D numbers
+    P_NUM=$(echo "$config" | grep -oP '(\d+)(?=P)' || echo "1")
+    D_NUM=$(echo "$config" | grep -oP '(\d+)(?=D)' || echo "1")
+    
+    # Total TP = P + D
+    TOTAL_TP=$((P_NUM + D_NUM))
+    
+    # Set affinity masks
+    # BASELINE uses all tiles
+    BASELINE_AFFINITY="0"
+    if [ "$TOTAL_TP" -gt 1 ]; then
+        for ((i=1; i<TOTAL_TP; i++)); do
+            BASELINE_AFFINITY="${BASELINE_AFFINITY},$i"
+        done
+    fi
+    
+    # PREFILL uses first P_NUM tiles
+    PREFILL_AFFINITY="0"
+    if [ "$P_NUM" -gt 1 ]; then
+        for ((i=1; i<P_NUM; i++)); do
+            PREFILL_AFFINITY="${PREFILL_AFFINITY},$i"
+        done
+    fi
+    
+    # DECODE uses last D_NUM tiles
+    DECODE_AFFINITY="$P_NUM"
+    if [ "$D_NUM" -gt 1 ]; then
+        for ((i=1; i<D_NUM; i++)); do
+            DECODE_AFFINITY="${DECODE_AFFINITY},$((P_NUM + i))"
+        done
+    fi
+    
+    # Set tp values (P and DECODE use their respective TP counts)
+    PREFILL_TP="$P_NUM"
+    DECODE_TP="$D_NUM"
+}
+
 # Hosts / ports
 PREFILL_HOST=${PREFILL_HOST:-"localhost"}
 PREFILL_PORT=${PREFILL_PORT:-8100}

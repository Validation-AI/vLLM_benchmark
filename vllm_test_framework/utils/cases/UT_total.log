pytest -v -s tests/compile/fusions_e2e/test_tp1_quant.py -k 'inductor_partition and (FLASHINFER and not +rms_norm and (not +quant_fp8 or +quant_fp8 and (qwen3 or deepseek)) or llama-3)'
